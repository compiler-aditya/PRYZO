FIRECRAWL_API_KEY=fc-...
ELEVENLABS_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# SMTP for Watch Mode email alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ElevenLabs Agent
HUNT_AGENT_ID=

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/pryzo

# Auth secret for server tool calls
BACKEND_SECRET=dev-secret

# Web Push VAPID keys (optional, generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
